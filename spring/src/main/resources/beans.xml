<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="singletonItem" class="com.example.spring.Item" scope="singleton">
    <property name="id" value="1"/>
    <property name="name" value="Laptop"/>
    <property name="price" value="50000"/>
</bean>

<bean id="prototypeItem" class="com.example.spring.Item" scope="prototype">
    <property name="id" value="2"/>
    <property name="name" value="Mobile"/>
    <property name="price" value="20000"/>
</bean>

</beans>